# 逗号分隔的前端开发地址（CORS）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─────────────────────────────────────────────────────────────
# Neo4j（图谱查询 /api/v1/graph/*）
# ─────────────────────────────────────────────────────────────
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
NEO4J_GRAPH_MODE=schema
NEO4J_ONTOLOGY_TRACE=0
NEO4J_GRAPH_PANORAMA=true
NEO4J_GRAPH_LIMIT=4000
NEO4J_PANORAMA_NODE_LIMIT=8000
NEO4J_IGNORE_LABELS=__Meta__,__Internal__
# NEO4J_KIND_LABELS={"event":["Event"],"master":["MasterDataEntity"],"subobject":["OrderLine"],"object":["Entity"]}

# ─────────────────────────────────────────────────────────────
# PostgreSQL（关系型数据 /api/v1/data/*）
# ─────────────────────────────────────────────────────────────
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=erpagent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_POOL_MIN=1
POSTGRES_POOL_MAX=10

# ─────────────────────────────────────────────────────────────
# JWT 认证（/api/v1/auth/*）
# ─────────────────────────────────────────────────────────────
# 生产环境务必修改为强随机密钥！建议使用: openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# ─────────────────────────────────────────────────────────────
# LLM（自然语言 → Cypher，/api/intelligence/query）
# ─────────────────────────────────────────────────────────────
LLM_PROVIDER=openai_compatible
LLM_API_BASE=
LLM_API_KEY=
LLM_MODEL=
# LLM_TIMEOUT_SECONDS=120

# NL 查询：无 LIMIT 时自动追加的上限；默认禁止 CALL
# NEO4J_NL_DEFAULT_LIMIT=200
# NEO4J_NL_ALLOW_CALL=0

# ERP 关系型→图映射
# ERP_MAPPING_DOC_APPEND=0
# ERP_MAPPING_DOC_PATH=/path/to/ERP 关系型模型到图模型的映射设计.md
# ERP_MAPPING_DOC_MAX_CHARS=14000
