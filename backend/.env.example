# 逗号分隔的前端开发地址（CORS）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Neo4j（左侧图谱 /api/graph/ontology）
NEO4J_URI=bolt://127.0.0.1:7687
# 必须与 Neo4j 中可登录的用户名一致（默认常为 neo4j）
NEO4J_USER=neo4j
# 该用户在 Neo4j 中的密码；勿提交到 Git。若含 # 等特殊字符：NEO4J_PASSWORD="你的密码"
NEO4J_PASSWORD=
# 逻辑库名（Neo4j 5+）。若报错 Database does not exist，在 Browser 执行 SHOW DATABASES 后填写
# NEO4J_DATABASE=neo4j
# 图谱 API 模式：schema=按标签+关系类型聚合的知识图谱（默认）；instances=具体节点子图
NEO4J_GRAPH_MODE=schema
# 为 true 时在终端打印 /api/graph/ontology 获取步骤（logger 始终会打 INFO，见 uvicorn --log-level info）
# NEO4J_ONTOLOGY_TRACE=1
# 全景：先拉有向关系，再补全库内节点（主数据/子对象等孤立点也会显示）
NEO4J_GRAPH_PANORAMA=true
# 单次查询最大关系条数
NEO4J_GRAPH_LIMIT=4000
# 全景补全时最多扫描的节点数（MATCH (n) RETURN n LIMIT …）
NEO4J_PANORAMA_NODE_LIMIT=8000
# 不参与的标签（逗号分隔）
NEO4J_IGNORE_LABELS=__Meta__,__Internal__
# 可选：JSON 覆盖各角色对应的 Neo4j 标签（含 master / subobject）
# NEO4J_KIND_LABELS={"event":["Event"],"master":["MasterDataEntity"],"subobject":["OrderLine"],"object":["Entity"]}

# ── LLM（自然语言 → Cypher，见 POST /api/intelligence/query）──
# 厂商：openai_compatible（OpenAI 兼容 /v1/chat/completions，含多数云与本地网关）
LLM_PROVIDER=openai_compatible
# 根地址即可：https://api.openai.com；若厂商已给「含 /v1」的 base，直接照填，不要重复 /v1
# （代码会自动拼 /v1/chat/completions，避免变成 .../v1/v1/...）
LLM_API_BASE=
LLM_API_KEY=
LLM_MODEL=
# LLM_TIMEOUT_SECONDS=120

# NL 查询：无 LIMIT 时自动追加的上限；默认禁止 CALL，读 db.labels 等需显式放开
# NEO4J_NL_DEFAULT_LIMIT=200
# NEO4J_NL_ALLOW_CALL=0

# ERP 关系型→图映射：默认使用 prompts 内提炼的 schema + 约束；设为 1 时再追加完整映射文档（截断见下）
# ERP_MAPPING_DOC_APPEND=0
# 附录文档路径（ERP_MAPPING_DOC_APPEND=1 时读取）；不设则用 backend/docs/erp_rdb_to_graph_mapping.md
# ERP_MAPPING_DOC_PATH=/path/to/ERP 关系型模型到图模型的映射设计.md
# 附录单次最大字符数
# ERP_MAPPING_DOC_MAX_CHARS=14000
