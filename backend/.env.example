# ============================================================
# ERP Agent 统一环境配置文件
# ============================================================
# 说明：
# 1. 复制此文件为 .env（在同一目录）
# 2. 根据实际环境修改配置值
# 3. .env 文件应加入 .gitignore，不要提交到 Git
# ============================================================

# ============================================================
# Neo4j 图数据库配置
# ============================================================
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=Tony1985
NEO4J_DATABASE=neo4j

# Neo4j 超时配置（秒）
NEO4J_TIMEOUT=20
NEO4J_CONNECTION_TIMEOUT=30
NEO4J_MAX_CONNECTION_LIFETIME=3600
NEO4J_MAX_CONNECTION_POOL_SIZE=50

# ============================================================
# PostgreSQL 数据库配置
# ============================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=erp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# PostgreSQL 连接池配置
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
POSTGRES_POOL_TIMEOUT=30
POSTGRES_POOL_RECYCLE=1800

# ============================================================
# Redis 缓存配置
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Redis 缓存过期时间（秒）
REDIS_DEFAULT_EXPIRE=3600
GSD_CACHE_EXPIRE=3600

# ============================================================
# FastAPI 后端服务配置
# ============================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8005
BACKEND_WORKERS=1
BACKEND_RELOAD=true

# CORS 配置（允许的前端地址）
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:5177,http://localhost:5178
CORS_ALLOW_CREDENTIALS=true

# ============================================================
# OpenClaw Gateway 配置
# ============================================================
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=3354bfe288d7b3d499d84d5b21d540ce21ff0c3e7dedbc18
OPENCLAW_GATEWAY_WS=ws://127.0.0.1:18789

# ============================================================
# GSD 智能问数配置
# ============================================================
GSD_API_VERSION=v25
GSD_CACHE_ENABLED=true
GSD_MAX_HISTORY=100
GSD_QUICK_QUERY_THRESHOLD=5

# ============================================================
# 日志配置
# ============================================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=logs/erp_agent.log

# ============================================================
# 安全配置
# ============================================================
# JWT 密钥（生产环境请使用强随机字符串）
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================
# 其他配置
# ============================================================
# 环境：development, staging, production
ENVIRONMENT=development

# 调试模式
DEBUG=true

# 时区
TIMEZONE=Asia/Shanghai
